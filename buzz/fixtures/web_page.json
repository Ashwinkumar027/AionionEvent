  "javascript": "let allEvents = [];\nasync function fetchEvents() {\n      try {\n              const res = await fetch('/api/method/buzz.api.get_published_events');\n                  const data = await res.json();\n                      allEvents = data.message || [];\n                          renderCards(allEvents);\n      } catch(e) { console.error(e); }\n}\nfunction renderCards(events) {\n      const grid = document.getElementById('events-grid');\n        if (!grid) return;\n          grid.innerHTML = '';\n            events.forEach(ev => {\n                    const card = document.createElement('div');\n                        card.className = 'bz-card';\n                            card.innerHTML = '<img class=\"bz-card-img\" src=\"' + (ev.image || 'https://picsum.photos/600/340') + '\"><div class=\"bz-card-body\"><h3>' + (ev.title||ev.name) + '</h3><p>' + (ev.venue||'Online') + '</p></div>';\n                                grid.appendChild(card);\n            });\n}\ndocument.addEventListener('DOMContentLoaded', fetchEvents);\n            })\n}\n      }\n}",
