  "main_section_html": "<div style=\"padding:40px\">\r\n\r\n  <h1 id=\"event-title\">Loading...</h1>\r\n\r\n  <img id=\"event-image\" style=\"width:400px;border-radius:10px\" />\r\n\r\n  <p><b>Date:</b> <span id=\"event-date\"></span></p>\r\n  <p><b>Venue:</b> <span id=\"event-venue\"></span></p>\r\n\r\n</div>\r\n<script>\r\ndocument.addEventListener(\"DOMContentLoaded\", async function () {\r\n\r\n  const route = window.location.pathname.split(\"/dashboard/book-tickets/\")[1];\r\n\r\n  console.log(\"Route:\", route);\r\n\r\n  const res = await fetch(`/api/method/get_event_by_route?route=${route}`);\r\n  const data = await res.json();\r\n\r\n  console.log(\"EVENT:\", data);\r\n\r\n  const ev = data.message;\r\n\r\n  if (!ev) {\r\n    document.body.innerHTML = \"<h2>Event Not Found</h2>\";\r\n    return;\r\n  }\r\n\r\n  document.getElementById(\"event-title\").innerText = ev.title;\r\n  document.getElementById(\"event-date\").innerText = ev.start_date;\r\n  document.getElementById(\"event-venue\").innerText = ev.venue;\r\n\r\n  if (ev.banner_image) {\r\n    document.getElementById(\"event-image\").src = ev.banner_image;\r\n  }\r\n\r\n});\r\n</script>",
