  "javascript": "<script>\r\nlet allEvents = [], currentFilter = 'all', currentCategory = '';\r\n\r\nasync function fetchEvents() {\r\n  try {\r\n    const res = await fetch('/api/method/get_published_events');\r\n    const data = await res.json();\r\n\r\n    allEvents = data.message || [];\r\n\r\n    const statEl = document.getElementById('stat-events');\r\n    if (statEl) statEl.textContent = allEvents.length + '+';\r\n\r\n    renderCards(allEvents);\r\n    renderFreeEvents();\r\n\r\n  } catch(e) {\r\n    console.error(\"Error loading events:\", e);\r\n    const emptyEl = document.getElementById('empty-state');\r\n    if (emptyEl) emptyEl.style.display = 'block';\r\n  }\r\n}\r\n\r\nfunction buildEventCard(ev) {\r\n  const card = document.createElement('div');\r\n  card.className = 'bz-card bz-real-card';\r\n\r\n  card.onclick = () => {\r\n  window.location = '/dashboard/book-tickets/' + ev.route;\r\n};\r\n\r\n  const imgSrc = ev.banner_image || ('https://picsum.photos/seed/' + ev.name + '/600/340');\r\n\r\n  const dateStr = ev.start_date\r\n    ? new Date(ev.start_date).toLocaleDateString('en-IN', {\r\n        day:'numeric', month:'short', year:'numeric'\r\n      })\r\n    : 'Date TBD';\r\n\r\n  const isFree = !ev.ticket_price || ev.ticket_price === 0;\r\n  const priceStr = isFree ? 'Free' : '₹' + ev.ticket_price;\r\n\r\n  card.innerHTML = `\r\n    <div class=\"bz-card-img-wrap\">\r\n      <img class=\"bz-card-img\" src=\"${imgSrc}\">\r\n    </div>\r\n    <div class=\"bz-card-body\">\r\n      <div class=\"bz-card-title\">${ev.title || ev.name}</div>\r\n      <div>📍 ${ev.venue || 'Venue TBD'}</div>\r\n      <div>📅 ${dateStr}</div>\r\n      <div>${priceStr}</div>\r\n    </div>\r\n  `;\r\n\r\n  return card;\r\n}\r\n\r\nfunction renderCards(events) {\r\n  const grid = document.getElementById('events-grid');\r\n  if (!grid) return;\r\n\r\n  grid.innerHTML = '';\r\n\r\n  if (!events.length) {\r\n    document.getElementById('empty-state').style.display = 'block';\r\n    return;\r\n  }\r\n\r\n  events.forEach(ev => grid.appendChild(buildEventCard(ev)));\r\n}\r\n\r\nfunction renderFreeEvents() {\r\n  const grid = document.getElementById('free-events-grid');\r\n  if (!grid) return;\r\n\r\n  grid.innerHTML = '';\r\n\r\n  const free = allEvents.filter(e => !e.ticket_price || e.ticket_price === 0);\r\n\r\n  free.slice(0,4).forEach(ev => grid.appendChild(buildEventCard(ev)));\r\n}\r\n\r\nfunction applyFilters() {\r\n  let result = [...allEvents];\r\n\r\n  if (currentCategory) {\r\n    result = result.filter(e =>\r\n      (e.event_category || '').toLowerCase() === currentCategory.toLowerCase()\r\n    );\r\n  }\r\n\r\n  let now = new Date();\r\n\r\n  if (currentFilter === 'today') {\r\n    result = result.filter(e => {\r\n      let d = new Date(e.start_date);\r\n      return d.toDateString() === now.toDateString();\r\n    });\r\n  }\r\n\r\n  if (currentFilter === 'week') {\r\n    let weekEnd = new Date();\r\n    weekEnd.setDate(now.getDate() + 7);\r\n\r\n    result = result.filter(e => {\r\n      let d = new Date(e.start_date);\r\n      return d >= now && d <= weekEnd;\r\n    });\r\n  }\r\n\r\n  if (currentFilter === 'free') {\r\n    result = result.filter(e => !e.ticket_price || e.ticket_price === 0);\r\n  }\r\n\r\n  renderCards(result);\r\n}\r\n\r\ndocument.addEventListener('DOMContentLoaded', () => {\r\n  fetchEvents();\r\n});\r\n</script>\r\n",
  "main_section": null,
  "main_section_html": "<nav class=\"bz-nav\">\r\n  <div class=\"bz-nav-inner\">\r\n    <div class=\"bz-logo\">⚡ Buzz</div>\r\n    <div class=\"bz-nav-search\">\r\n      <svg width=\"16\" height=\"16\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" viewBox=\"0 0 24 24\"><circle cx=\"11\" cy=\"11\" r=\"8\"/><path d=\"M21 21l-4.35-4.35\"/></svg>\r\n      <input id=\"nav-search-input\" type=\"text\" placeholder=\"Search concerts, sports, workshops…\" autocomplete=\"off\">\r\n    </div>\r\n    <div class=\"bz-nav-actions\">\r\n      <button class=\"bz-btn-ghost\" onclick=\"window.location='/events'\">Browse Events</button>\r\n      <button class=\"bz-btn-primary\" onclick=\"window.location='/login'\">Sign In</button>\r\n    </div>\r\n  </div>\r\n</nav>\r\n\r\n<section class=\"bz-hero\">\r\n  <div class=\"bz-hero-bg\"></div>\r\n  <div class=\"bz-hero-overlay\"></div>\r\n  <div class=\"bz-hero-content\">\r\n    <div class=\"bz-hero-badge\">🎉 1000+ Events Live Now</div>\r\n    <h1 class=\"bz-hero-title\">Discover Your Next<br><span>Unforgettable Experience</span></h1>\r\n    <p class=\"bz-hero-sub\">Concerts, workshops, sports &amp; more — all in one place. Book instantly.</p>\r\n    <div class=\"bz-search-bar\">\r\n      <svg width=\"18\" height=\"18\" fill=\"none\" stroke=\"#9ca3af\" stroke-width=\"2\" viewBox=\"0 0 24 24\"><circle cx=\"11\" cy=\"11\" r=\"8\"/><path d=\"M21 21l-4.35-4.35\"/></svg>\r\n      <input id=\"hero-search\" type=\"text\" placeholder=\"Search events, artists, venues…\" autocomplete=\"off\">\r\n      <button class=\"bz-search-btn\" onclick=\"doSearch()\">Search</button>\r\n    </div>\r\n    <div class=\"bz-chips\">\r\n      <div class=\"bz-chip active\" data-cat=\"\">All Events</div>\r\n      <div class=\"bz-chip\" data-cat=\"Concert\">🎵 Concerts</div>\r\n      <div class=\"bz-chip\" data-cat=\"Sports\">⚽ Sports</div>\r\n      <div class=\"bz-chip\" data-cat=\"Workshop\">🎓 Workshops</div>\r\n      <div class=\"bz-chip\" data-cat=\"Comedy\">😂 Comedy</div>\r\n      <div class=\"bz-chip\" data-cat=\"Tech\">💻 Tech</div>\r\n    </div>\r\n  </div>\r\n</section>\r\n\r\n<div class=\"bz-stats-strip\">\r\n  <div class=\"bz-stats-inner\">\r\n    <div class=\"bz-stat\"><div class=\"bz-stat-num\" id=\"stat-events\">—</div><div class=\"bz-stat-lbl\">Live Events</div></div>\r\n    <div class=\"bz-stat\"><div class=\"bz-stat-num\">50+</div><div class=\"bz-stat-lbl\">Cities</div></div>\r\n    <div class=\"bz-stat\"><div class=\"bz-stat-num\">10k+</div><div class=\"bz-stat-lbl\">Happy Attendees</div></div>\r\n    <div class=\"bz-stat\"><div class=\"bz-stat-num\">100%</div><div class=\"bz-stat-lbl\">Secure Booking</div></div>\r\n  </div>\r\n</div>\r\n\r\n<section class=\"bz-section\">\r\n  <div class=\"bz-section-header\">\r\n    <h2 class=\"bz-section-title\">🔥 Trending Events</h2>\r\n    <a class=\"bz-view-all\" href=\"/events\">View all →</a>\r\n  </div>\r\n  <div class=\"bz-filter-tabs\">\r\n    <button class=\"bz-tab active\" data-filter=\"all\">All Events</button>\r\n    <button class=\"bz-tab\" data-filter=\"today\">Today</button>\r\n    <button class=\"bz-tab\" data-filter=\"week\">This Week</button>\r\n    <button class=\"bz-tab\" data-filter=\"free\">Free Events 🎉</button>\r\n  </div>\r\n  <div class=\"bz-grid\" id=\"events-grid\">\r\n    <div class=\"bz-card\" id=\"sk1\" style=\"pointer-events:none\"><div class=\"bz-skeleton\" style=\"height:170px\"></div><div class=\"bz-card-body\" style=\"gap:10px\"><div class=\"bz-skeleton\" style=\"height:18px;width:80%\"></div><div class=\"bz-skeleton\" style=\"height:14px;width:55%\"></div></div></div>\r\n    <div class=\"bz-card\" id=\"sk2\" style=\"pointer-events:none\"><div class=\"bz-skeleton\" style=\"height:170px\"></div><div class=\"bz-card-body\" style=\"gap:10px\"><div class=\"bz-skeleton\" style=\"height:18px;width:70%\"></div><div class=\"bz-skeleton\" style=\"height:14px;width:50%\"></div></div></div>\r\n    <div class=\"bz-card\" id=\"sk3\" style=\"pointer-events:none\"><div class=\"bz-skeleton\" style=\"height:170px\"></div><div class=\"bz-card-body\" style=\"gap:10px\"><div class=\"bz-skeleton\" style=\"height:18px;width:75%\"></div><div class=\"bz-skeleton\" style=\"height:14px;width:45%\"></div></div></div>\r\n    <div class=\"bz-card\" id=\"sk4\" style=\"pointer-events:none\"><div class=\"bz-skeleton\" style=\"height:170px\"></div><div class=\"bz-card-body\" style=\"gap:10px\"><div class=\"bz-skeleton\" style=\"height:18px;width:65%\"></div><div class=\"bz-skeleton\" style=\"height:14px;width:60%\"></div></div></div>\r\n  </div>\r\n  <div class=\"bz-empty\" id=\"empty-state\"><p>No events found. Check back soon!</p></div>\r\n</section>\r\n\r\n<section class=\"bz-section\" style=\"padding-top:0\" id=\"free-section\">\r\n  <div class=\"bz-section-header\">\r\n    <h2 class=\"bz-section-title\">🎉 Free Events</h2>\r\n    <a class=\"bz-view-all\" href=\"/events?free=1\">View all →</a>\r\n  </div>\r\n  <div class=\"bz-grid\" id=\"free-events-grid\"></div>\r\n</section>\r\n\r\n<div class=\"bz-newsletter\">\r\n  <h2>Stay in the Loop 🔔</h2>\r\n  <p>Get notified about upcoming events, early-bird tickets, and exclusive deals.</p>\r\n  <div class=\"bz-nl-form\">\r\n    <input type=\"email\" id=\"nl-email\" placeholder=\"Enter your email address\">\r\n    <button onclick=\"subscribeNewsletter()\">Subscribe</button>\r\n  </div>\r\n</div>\r\n\r\n<footer>\r\n  <div class=\"bz-footer-inner\">\r\n    <div class=\"bz-footer-logo\">⚡ Buzz</div>\r\n    <div class=\"bz-footer-links\">\r\n      <a href=\"/events\">Events</a>\r\n      <a href=\"/about\">About</a>\r\n      <a href=\"/contact\">Contact</a>\r\n      <a href=\"/privacy\">Privacy</a>\r\n    </div>\r\n    <div style=\"font-size:12px\">© 2025 Buzz. All rights reserved.</div>\r\n  </div>\r\n</footer>\r\n```\r\n\r\n**Step 6: Head HTML / CSS**\r\n\r\nLook for a field/tab called \"Head HTML\" or \"head_include\" or \"Style\". Paste this CSS there:\r\n\r\n```\r\n<link rel=\"preconnect\" href=\"https://fonts.googleapis.com\">\r\n<link href=\"https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap\" rel=\"stylesheet\">\r\n<style>\r\n  :root { --primary: #FF6B35; --primary-2: #FB426E; --gradient: linear-gradient(135deg, #FF6B35, #FB426E); --dark: #0B0B14; --card-bg: #ffffff; --body-bg: #F5F5F8; --text-main: #111827; --text-muted: #6B7280; --border: rgba(0,0,0,0.07); --shadow: 0 4px 24px rgba(0,0,0,0.09); --radius: 18px; }\r\n  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }\r\n  body { font-family: 'Inter', sans-serif; background: var(--body-bg); color: var(--text-main); }\r\n  a { text-decoration: none; color: inherit; }\r\n  .bz-nav { position: sticky; top: 0; z-index: 100; background: #fff; border-bottom: 1px solid var(--border); padding: 0 32px; }\r\n  .bz-nav-inner { max-width: 1280px; margin: 0 auto; display: flex; align-items: center; gap: 16px; height: 64px; }\r\n  .bz-logo { font-size: 22px; font-weight: 900; letter-spacing: -0.5px; background: var(--gradient); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; flex-shrink: 0; }\r\n  .bz-nav-search { flex: 1; max-width: 480px; display: flex; align-items: center; gap: 8px; background: #f3f4f6; border-radius: 50px; padding: 8px 16px; border: 1.5px solid transparent; transition: border-color .2s; }\r\n  .bz-nav-search:focus-within { border-color: var(--primary); background: #fff; }\r\n  .bz-nav-search input { border: none; background: transparent; outline: none; font-size: 14px; width: 100%; color: var(--text-main); font-family: inherit; }\r\n  .bz-nav-search input::placeholder { color: #9ca3af; }\r\n  .bz-nav-actions { margin-left: auto; display: flex; align-items: center; gap: 10px; }\r\n  .bz-btn-ghost { padding: 8px 18px; border-radius: 50px; font-size: 14px; font-weight: 500; cursor: pointer; border: 1.5px solid #e5e7eb; background: transparent; color: var(--text-main); transition: all .2s; font-family: inherit; }\r\n  .bz-btn-ghost:hover { border-color: var(--primary); color: var(--primary); }\r\n  .bz-btn-primary { padding: 8px 20px; border-radius: 50px; font-size: 14px; font-weight: 600; cursor: pointer; border: none; background: var(--gradient); color: #fff; transition: opacity .2s, transform .15s; font-family: inherit; }\r\n  .bz-hero { position: relative; min-height: 480px; display: flex; align-items: center; overflow: hidden; background: linear-gradient(135deg, #0B0B14 0%, #1a1a2e 50%, #16213e 100%); }\r\n  .bz-hero-bg { position: absolute; inset: 0; background: url('https://images.unsplash.com/photo-1492684223066-81342ee5ff30?w=1600&q=80') center/cover no-repeat; opacity: .18; }\r\n  .bz-hero-overlay { position: absolute; inset: 0; background: linear-gradient(to bottom, rgba(11,11,20,0.7) 0%, rgba(11,11,20,0.85) 100%); }\r\n  .bz-hero-content { position: relative; z-index: 2; max-width: 1280px; margin: 0 auto; padding: 72px 32px 64px; width: 100%; text-align: center; }\r\n  .bz-hero-badge { display: inline-block; margin-bottom: 18px; background: rgba(255,255,255,0.08); border: 1px solid rgba(255,255,255,0.15); color: #fff; font-size: 13px; font-weight: 500; padding: 6px 16px; border-radius: 50px; }\r\n  .bz-hero-title { font-size: clamp(32px, 5vw, 58px); font-weight: 900; color: #fff; line-height: 1.15; margin-bottom: 16px; letter-spacing: -1.5px; }\r\n  .bz-hero-title span { background: var(--gradient); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }\r\n  .bz-hero-sub { color: rgba(255,255,255,0.65); font-size: 17px; margin-bottom: 36px; max-width: 520px; margin-left: auto; margin-right: auto; }\r\n  .bz-search-bar { display: flex; align-items: center; background: #fff; border-radius: 16px; padding: 6px 6px 6px 20px; box-shadow: 0 16px 48px rgba(0,0,0,0.35); max-width: 600px; margin: 0 auto 28px; gap: 8px; }\r\n  .bz-search-bar input { flex: 1; border: none; outline: none; font-size: 15px; color: var(--text-main); background: transparent; font-family: inherit; }\r\n  .bz-search-bar input::placeholder { color: #9ca3af; }\r\n  .bz-search-btn { padding: 12px 24px; border-radius: 12px; background: var(--gradient); color: #fff; font-weight: 600; font-size: 14px; border: none; cursor: pointer; white-space: nowrap; }\r\n  .bz-chips { display: flex; gap: 8px; justify-content: center; flex-wrap: wrap; }\r\n  .bz-chip { padding: 8px 18px; border-radius: 50px; font-size: 13px; font-weight: 500; border: 1.5px solid rgba(255,255,255,0.2); color: rgba(255,255,255,0.85); background: rgba(255,255,255,0.06); cursor: pointer; transition: all .2s; user-select: none; }\r\n  .bz-chip:hover, .bz-chip.active { background: var(--gradient); border-color: transparent; color: #fff; }\r\n  .bz-section { max-width: 1280px; margin: 0 auto; padding: 52px 32px; }\r\n  .bz-section-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 28px; }\r\n  .bz-section-title { font-size: 24px; font-weight: 800; letter-spacing: -0.5px; }\r\n  .bz-view-all { font-size: 14px; font-weight: 600; color: var(--primary); display: flex; align-items: center; gap: 4px; cursor: pointer; }\r\n  .bz-filter-tabs { display: flex; gap: 8px; margin-bottom: 28px; flex-wrap: wrap; }\r\n  .bz-tab { padding: 8px 18px; border-radius: 50px; font-size: 13px; font-weight: 500; border: 1.5px solid var(--border); color: var(--text-muted); background: #fff; cursor: pointer; transition: all .2s; font-family: inherit; }\r\n  .bz-tab:hover { border-color: var(--primary); color: var(--primary); }\r\n  .bz-tab.active { background: var(--gradient); border-color: transparent; color: #fff; }\r\n  .bz-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 24px; }\r\n  .bz-card { background: var(--card-bg); border-radius: var(--radius); box-shadow: var(--shadow); overflow: hidden; transition: transform .25s, box-shadow .25s; cursor: pointer; display: flex; flex-direction: column; }\r\n  .bz-card:hover { transform: translateY(-6px); box-shadow: 0 16px 40px rgba(0,0,0,0.14); }\r\n  .bz-card-img-wrap { position: relative; aspect-ratio: 16/9; overflow: hidden; }\r\n  .bz-card-img { width: 100%; height: 100%; object-fit: cover; transition: transform .4s ease; }\r\n  .bz-card:hover .bz-card-img { transform: scale(1.06); }\r\n  .bz-card-img-overlay { position: absolute; inset: 0; background: linear-gradient(180deg, transparent 50%, rgba(0,0,0,0.6) 100%); }\r\n  .bz-card-badge { position: absolute; top: 12px; left: 12px; background: var(--gradient); color: #fff; font-size: 11px; font-weight: 700; letter-spacing: .5px; padding: 4px 10px; border-radius: 50px; text-transform: uppercase; }\r\n  .bz-card-body { padding: 16px 18px 18px; flex: 1; display: flex; flex-direction: column; gap: 8px; }\r\n  .bz-card-title { font-size: 16px; font-weight: 700; line-height: 1.35; color: var(--text-main); display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }\r\n  .bz-card-location { display: flex; align-items: center; gap: 5px; font-size: 13px; color: var(--text-muted); }\r\n  .bz-card-footer { display: flex; align-items: center; justify-content: space-between; margin-top: auto; padding-top: 12px; border-top: 1px solid var(--border); }\r\n  .bz-card-date { display: flex; align-items: center; gap: 5px; font-size: 13px; font-weight: 500; color: #059669; }\r\n  .bz-price { font-size: 14px; font-weight: 700; background: var(--gradient); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }\r\n  .bz-price.free { -webkit-text-fill-color: #059669; background: none; color: #059669; }\r\n  .bz-skeleton { background: linear-gradient(90deg, #f0f0f0 25%, #e0e0e0 50%, #f0f0f0 75%); background-size: 200% 100%; animation: shimmer 1.4s infinite; border-radius: 10px; }\r\n  @keyframes shimmer { 0%{background-position:200% 0} 100%{background-position:-200% 0} }\r\n  .bz-empty { text-align: center; padding: 60px 24px; color: var(--text-muted); display: none; }\r\n  .bz-stats-strip { background: var(--gradient); padding: 28px 32px; }\r\n  .bz-stats-inner { max-width: 1280px; margin: 0 auto; display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px; text-align: center; }\r\n  .bz-stat { color: #fff; }\r\n  .bz-stat-num { font-size: 32px; font-weight: 900; letter-spacing: -1px; }\r\n  .bz-stat-lbl { font-size: 13px; opacity: .8; margin-top: 2px; }\r\n  .bz-newsletter { background: linear-gradient(135deg, #0B0B14, #1a1a2e); padding: 64px 32px; text-align: center; }\r\n  .bz-newsletter h2 { font-size: 32px; font-weight: 900; color: #fff; margin-bottom: 10px; }\r\n  .bz-newsletter p { color: rgba(255,255,255,0.6); margin-bottom: 28px; font-size: 15px; }\r\n  .bz-nl-form { display: flex; gap: 8px; max-width: 440px; margin: 0 auto; }\r\n  .bz-nl-form input { flex: 1; padding: 14px 18px; border-radius: 12px; border: 1.5px solid rgba(255,255,255,0.1); background: rgba(255,255,255,0.06); color: #fff; font-size: 14px; outline: none; font-family: inherit; }\r\n  .bz-nl-form input::placeholder { color: rgba(255,255,255,0.35); }\r\n  .bz-nl-form button { padding: 14px 24px; border-radius: 12px; background: var(--gradient); border: none; color: #fff; font-weight: 600; font-size: 14px; cursor: pointer; font-family: inherit; }\r\n  footer { background: #0B0B14; color: rgba(255,255,255,0.5); padding: 40px 32px 24px; }\r\n  .bz-footer-inner { max-width: 1280px; margin: 0 auto; display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 16px; }\r\n  .bz-footer-logo { font-size: 20px; font-weight: 900; background: var(--gradient); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }\r\n  .bz-footer-links { display: flex; gap: 20px; }\r\n  .bz-footer-links a { font-size: 13px; transition: color .2s; }\r\n  .bz-footer-links a:hover { color: var(--primary); }\r\n  @media(max-width: 768px) {\r\n    .bz-nav-search { display: none; }\r\n    .bz-stats-inner { grid-template-columns: repeat(2, 1fr); }\r\n    .bz-nl-form { flex-direction: column; }\r\n    .bz-footer-inner { flex-direction: column; text-align: center; }\r\n    .bz-section { padding: 32px 16px; }\r\n  }\r\n</style>\r\n<script>\r\nlet allEvents = [], currentFilter = 'all', currentCategory = '';\r\n\r\nasync function fetchEvents() {\r\n  try {\r\n    const res = await fetch('/api/method/get_published_events');\r\n    const data = await res.json();\r\n\r\n    console.log(\"API DATA:\", data); // DEBUG\r\n\r\n    allEvents = data.message || [];\r\n\r\n    const statEl = document.getElementById('stat-events');\r\n    if (statEl) statEl.textContent = allEvents.length + '+';\r\n\r\n    // remove skeletons\r\n    ['sk1','sk2','sk3','sk4'].forEach(id => {\r\n      const el = document.getElementById(id);\r\n      if (el) el.remove();\r\n    });\r\n\r\n    renderCards(allEvents);\r\n    renderFreeEvents();\r\n\r\n  } catch(e) {\r\n    console.error(\"Error:\", e);\r\n    document.getElementById('empty-state').style.display = 'block';\r\n  }\r\n}\r\n\r\nfunction buildEventCard(ev) {\r\n  const card = document.createElement('div');\r\n  card.className = 'bz-card bz-real-card';\r\n\r\n card.onclick = () => {\r\n  window.location = '/dashboard/book-tickets/' + ev.route;\r\n };\r\n\r\n  const imgSrc = ev.banner_image || 'https://picsum.photos/seed/' + ev.name + '/600/340';\r\n\r\n  const dateStr = ev.start_date\r\n    ? new Date(ev.start_date).toLocaleDateString('en-IN',{day:'numeric',month:'short',year:'numeric'})\r\n    : 'Date TBD';\r\n\r\n  const isFree = !ev.ticket_price || ev.ticket_price === 0;\r\n  const priceStr = isFree ? 'Free' : '₹' + ev.ticket_price;\r\n\r\n  card.innerHTML = `\r\n    <div class=\"bz-card-img-wrap\">\r\n      <img class=\"bz-card-img\" src=\"${imgSrc}\">\r\n    </div>\r\n    <div class=\"bz-card-body\">\r\n      <div class=\"bz-card-title\">${ev.title || ev.name}</div>\r\n      <div class=\"bz-card-location\">📍 ${ev.venue || 'Venue TBD'}</div>\r\n      <div class=\"bz-card-footer\">\r\n        <div class=\"bz-card-date\">📅 ${dateStr}</div>\r\n        <span class=\"bz-price ${isFree ? 'free' : ''}\">${priceStr}</span>\r\n      </div>\r\n    </div>\r\n  `;\r\n\r\n  return card;\r\n}\r\n\r\nfunction renderCards(events) {\r\n  const grid = document.getElementById('events-grid');\r\n  if (!grid) return;\r\n\r\n  grid.querySelectorAll('.bz-real-card').forEach(c => c.remove());\r\n\r\n  if (!events.length) {\r\n    document.getElementById('empty-state').style.display = 'block';\r\n    return;\r\n  }\r\n\r\n  document.getElementById('empty-state').style.display = 'none';\r\n\r\n  events.forEach(ev => grid.appendChild(buildEventCard(ev)));\r\n}\r\n\r\nfunction renderFreeEvents() {\r\n  const grid = document.getElementById('free-events-grid');\r\n  if (!grid) return;\r\n\r\n  grid.innerHTML = '';\r\n\r\n  const free = allEvents.filter(e => !e.ticket_price || e.ticket_price === 0);\r\n\r\n  free.slice(0,4).forEach(ev => grid.appendChild(buildEventCard(ev)));\r\n}\r\n\r\ndocument.addEventListener('DOMContentLoaded', function() {\r\n  fetchEvents();\r\n});\r\n</script>\r\n",
