  "javascript": "document.addEventListener(\"DOMContentLoaded\", async function () {\r\n\r\n  try {\r\n    // ✅ Get route from URL\r\n    const route = window.location.pathname.split(\"/dashboard/book-tickets/\")[1];\r\n\r\n    console.log(\"Route:\", route);\r\n\r\n    // ✅ Call Server Script API\r\n    const res = await fetch(`/api/method/get_event_by_route?route=${route}`);\r\n    const data = await res.json();\r\n\r\n    console.log(\"Event Data:\", data);\r\n\r\n    const ev = data.message;\r\n\r\n    // ❌ If no event\r\n    if (!ev) {\r\n      document.body.innerHTML = \"<h2 style='text-align:center;margin-top:50px'>Event Not Found</h2>\";\r\n      return;\r\n    }\r\n\r\n    // ✅ Update UI\r\n    document.getElementById(\"event-title\").innerText = ev.title || ev.name;\r\n    document.getElementById(\"event-date\").innerText = ev.start_date || '';\r\n    document.getElementById(\"event-venue\").innerText = ev.venue || '';\r\n\r\n    if (ev.banner_image) {\r\n      document.getElementById(\"event-image\").src = ev.banner_image;\r\n    }\r\n\r\n  } catch (err) {\r\n    console.error(\"Error loading event:\", err);\r\n  }\r\n\r\n});",
