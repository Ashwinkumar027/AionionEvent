  "main_section_html": "<link rel=\"preconnect\" href=\"https://fonts.googleapis.com\">\n<link href=\"https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap\" rel=\"stylesheet\">\n<style>\n    :root{--primary:#FF6B35;--primary-2:#FB426E;--gradient:linear-gradient(135deg,#FF6B35,#FB426E);--dark:#0B0B14;--card-bg:#ffffff;--body-bg:#F5F5F8;--text-main:#111827;--text-muted:#6B7280;--border:rgba(0,0,0,0.07);--shadow:0 4px 24px rgba(0,0,0,0.09);--radius:18px}\n    *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}\n    body{font-family:'Inter',sans-serif;background:var(--body-bg);color:var(--text-main);-webkit-font-smoothing:antialiased}\n    a{text-decoration:none;color:inherit}\n    .bz-nav{position:sticky;top:0;z-index:100;background:#fff;border-bottom:1px solid var(--border);padding:0 32px}\n    .bz-nav-inner{max-width:1280px;margin:0 auto;display:flex;align-items:center;gap:16px;height:64px}\n    .bz-logo{font-size:22px;font-weight:900;letter-spacing:-0.5px;background:var(--gradient);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;flex-shrink:0}\n    .bz-nav-search{flex:1;max-width:480px;display:flex;align-items:center;gap:8px;background:#f3f4f6;border-radius:50px;padding:8px 16px;border:1.5px solid transparent;transition:border-color .2s}\n    .bz-nav-search:focus-within{border-color:var(--primary);background:#fff}\n    .bz-nav-search input{border:none;background:transparent;outline:none;font-size:14px;width:100%;color:var(--text-main);font-family:inherit}\n    .bz-nav-search input::placeholder{color:#9ca3af}\n    .bz-nav-actions{margin-left:auto;display:flex;align-items:center;gap:10px}\n    .bz-btn-ghost{padding:8px 18px;border-radius:50px;font-size:14px;font-weight:500;cursor:pointer;border:1.5px solid #e5e7eb;background:transparent;color:var(--text-main);transition:all .2s;font-family:inherit}\n    .bz-btn-ghost:hover{border-color:var(--primary);color:var(--primary)}\n    .bz-btn-primary{padding:8px 20px;border-radius:50px;font-size:14px;font-weight:600;cursor:pointer;border:none;background:var(--gradient);color:#fff;transition:opacity .2s,transform .15s;font-family:inherit}\n    .bz-btn-primary:hover{opacity:.9;transform:scale(1.02)}\n    .bz-hero{position:relative;min-height:480px;display:flex;align-items:center;overflow:hidden;background:linear-gradient(135deg,#0B0B14 0%,#1a1a2e 50%,#16213e 100%)}\n    .bz-hero-bg{position:absolute;inset:0;background:url('https://images.unsplash.com/photo-1492684223066-81342ee5ff30?w=1600&q=80') center/cover no-repeat;opacity:.18}\n    .bz-hero-overlay{position:absolute;inset:0;background:linear-gradient(to bottom,rgba(11,11,20,0.7) 0%,rgba(11,11,20,0.85) 100%)}\n    .bz-hero-content{position:relative;z-index:2;max-width:1280px;margin:0 auto;padding:72px 32px 64px;width:100%;text-align:center}\n    .bz-hero-badge{display:inline-block;margin-bottom:18px;background:rgba(255,255,255,0.08);border:1px solid rgba(255,255,255,0.15);color:#fff;font-size:13px;font-weight:500;padding:6px 16px;border-radius:50px}\n    .bz-hero-title{font-size:clamp(32px,5vw,58px);font-weight:900;color:#fff;line-height:1.15;margin-bottom:16px;letter-spacing:-1.5px}\n    .bz-hero-title span{background:var(--gradient);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}\n    .bz-hero-sub{color:rgba(255,255,255,0.65);font-size:17px;margin-bottom:36px;max-width:520px;margin-left:auto;margin-right:auto}\n    .bz-search-bar{display:flex;align-items:center;background:#fff;border-radius:16px;padding:6px 6px 6px 20px;box-shadow:0 16px 48px rgba(0,0,0,0.35);max-width:600px;margin:0 auto 28px;gap:8px}\n    .bz-search-bar input{flex:1;border:none;outline:none;font-size:15px;color:var(--text-main);background:transparent;font-family:inherit}\n    .bz-search-bar input::placeholder{color:#9ca3af}\n    .bz-search-btn{padding:12px 24px;border-radius:12px;background:var(--gradient);color:#fff;font-weight:600;font-size:14px;border:none;cursor:pointer;white-space:nowrap}\n    .bz-chips{display:flex;gap:8px;justify-content:center;flex-wrap:wrap}\n    .bz-chip{padding:8px 18px;border-radius:50px;font-size:13px;font-weight:500;border:1.5px solid rgba(255,255,255,0.2);color:rgba(255,255,255,0.85);background:rgba(255,255,255,0.06);cursor:pointer;transition:all .2s;user-select:none}\n    .bz-chip:hover,.bz-chip.active{background:var(--gradient);border-color:transparent;color:#fff}\n    .bz-section{max-width:1280px;margin:0 auto;padding:52px 32px}\n    .bz-section-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:28px}\n    .bz-section-title{font-size:24px;font-weight:800;letter-spacing:-0.5px}\n    .bz-view-all{font-size:14px;font-weight:600;color:var(--primary);display:flex;align-items:center;gap:4px;cursor:pointer}\n    .bz-filter-tabs{display:flex;gap:8px;margin-bottom:28px;flex-wrap:wrap}\n    .bz-tab{padding:8px 18px;border-radius:50px;font-size:13px;font-weight:500;border:1.5px solid var(--border);color:var(--text-muted);background:#fff;cursor:pointer;transition:all .2s;font-family:inherit}\n    .bz-tab:hover{border-color:var(--primary);color:var(--primary)}\n    .bz-tab.active{background:var(--gradient);border-color:transparent;color:#fff}\n    .bz-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:24px}\n    .bz-card{background:var(--card-bg);border-radius:var(--radius);box-shadow:var(--shadow);overflow:hidden;transition:transform .25s,box-shadow .25s;cursor:pointer;display:flex;flex-direction:column}\n    .bz-card:hover{transform:translateY(-6px);box-shadow:0 16px 40px rgba(0,0,0,0.14)}\n    .bz-card-img-wrap{position:relative;aspect-ratio:16/9;overflow:hidden}\n    .bz-card-img{width:100%;height:100%;object-fit:cover;transition:transform .4s ease}\n    .bz-card:hover .bz-card-img{transform:scale(1.06)}\n    .bz-card-img-overlay{position:absolute;inset:0;background:linear-gradient(180deg,transparent 50%,rgba(0,0,0,0.6) 100%)}\n    .bz-card-badge{position:absolute;top:12px;left:12px;background:var(--gradient);color:#fff;font-size:11px;font-weight:700;letter-spacing:.5px;padding:4px 10px;border-radius:50px;text-transform:uppercase}\n    .bz-card-body{padding:16px 18px 18px;flex:1;display:flex;flex-direction:column;gap:8px}\n    .bz-card-title{font-size:16px;font-weight:700;line-height:1.35;color:var(--text-main);display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden}\n    .bz-card-location{display:flex;a;\n</style><nav class=\"bz-nav\">\n      <div class=\"bz-nav-inner\">\n              <div class=\"bz-logo\">Buzz</div>\n                  <div class=\"bz-nav-actions\">\n                            <button onclick=\"window.location='/login'\">Sign In</button>\n                                </div>\n                                  </div>\n                                  </nav>\n                                  \n                                  <section class=\"bz-hero\">\n                                        <div class=\"bz-hero-content\">\n                                                <h1>Discover Unforgettable Experiences</h1>\n                                                    <div class=\"bz-search-bar\">\n                                                              <input id=\"hero-search\" type=\"text\" placeholder=\"Search events...\">\n                                                                    <button onclick=\"alert('Searching...')\">Search</button>\n                                                                        </div>\n                                                                          </div>\n                                                                          </section>\n                                                                          \n                                                                          <section class=\"bz-section\" style=\"padding: 40px;\">\n                                                                                <h2>Trending Events</h2>\n                                                                                  <div class=\"bz-grid\" id=\"events-grid\">\n                                                                                          <div class=\"bz-card\">Loading...</div>\n                                                                                            </div>\n                                                                                            </section>\n                                                                                            \n                                                                                            <footer>\n                                                                                                  <div class=\"bz-footer-inner\">\n                                                                                                          <div class=\"bz-footer-logo\">Buzz</div>\n                                                                                                              <p>(c) 2025 Buzz</p>\n                                                                                                                </div>\n                                                                                                                </footer></p></div>\n                                                                                                  </div>\n                                                                                            </footer></div>\n                                                                                  </div></h2>\n                                                                          </section></button>\n                                                    </div></h1>\n                                        </div>\n                                  </section></button>\n                  </div></div>\n      </div>\n</nav>",
